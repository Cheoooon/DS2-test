<div class="max-w-md mx-auto bg-white p-8 rounded shadow">
  <h1 class="text-2xl font-bold mb-4">Register</h1>
  <form action="/register" method="POST" class="space-y-4">
    <input type="email" name="email" value="{{formData.email}}" placeholder="Email" class="w-full p-2 border rounded" required>
    {{#if errors.email}}<p class="text-red-500 text-xs mt-1">{{errors.email}}</p>{{/if}}
    <input type="password" name="password" placeholder="Password" class="w-full p-2 border rounded" required>
    {{#if errors.password}}<p class="text-red-500 text-xs mt-1">{{errors.password}}</p>{{/if}}
    <button type="submit" class="w-full bg-blue-500 text-white p-2 rounded hover:bg-blue-600">Register</button>
  </form>
</div>
