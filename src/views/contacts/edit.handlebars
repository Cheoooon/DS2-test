<div class="max-w-md mx-auto bg-white p-8 rounded shadow">
  <h1 class="text-2xl font-bold mb-4">Editar Contacto</h1>
  <form action="/contacts/edit/{{contact.id}}" method="POST" class="space-y-4">
    <input type="text" name="name" value="{{contact.name}}" class="w-full p-2 border rounded" required>
    <input type="text" name="alias" value="{{contact.alias}}" class="w-full p-2 border rounded">
    <input type="email" name="email" value="{{contact.email}}" class="w-full p-2 border rounded">
    <input type="text" name="phone" value="{{contact.phone}}" class="w-full p-2 border rounded">
    <button type="submit" class="w-full bg-blue-500 text-white p-2 rounded hover:bg-blue-600">Actualizar</button>
