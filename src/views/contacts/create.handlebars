<div class="max-w-md mx-auto bg-white p-8 rounded shadow">
{{#if errors}}
  <div class="bg-red-100 text-red-700 p-2 mb-4 rounded">
    {{#each errors}}
      <p>{{this.path}}: {{this.message}}</p>
    {{/each}}
  </div>
{{/if}}
  <h1 class="text-2xl font-bold mb-4">Crear Contacto</h1>
  <form action="/contacts" method="POST" class="space-y-4">
    <input type="text" name="name" placeholder="Nombre" class="w-full p-2 border rounded" required>
    <input type="text" name="alias" placeholder="Alias" class="w-full p-2 border rounded">
    <input type="email" name="email" placeholder="Email" class="w-full p-2 border rounded">
    <input type="text" name="phone" placeholder="Teléfono" class="w-full p-2 border rounded">
    <button type="submit" class="w-full bg-green-500 text-white p-2 rounded hover:bg-green-600">Guardar</button>
  </form>
</div>
